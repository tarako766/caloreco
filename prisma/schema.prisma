generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Memo {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  userId    String
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String?   @unique
  passwordHash   String
  age            Int
  gender         String
  heightCm       Float
  weightKg       Float
  /// AI が後から設定する目標 PFC（g/日）。現状は null
  targetProteinG Float?
  targetFatG     Float?
  targetCarbsG   Float?
  targetKcal     Float?
  pfcSetAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  targetWeightKg Float?
  bodyGoal       String?
  activityLevel  String?
  mealLogs       MealLog[]
}

model MealLog {
  id        Int      @id @default(autoincrement())
  rawInput  String
  result    Json
  createdAt DateTime @default(now())
  totalKcal Float?
  totalP    Float?
  totalF    Float?
  totalC    Float?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}
